<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="desktop_app.Vista.Home"
        Title="Home"
		Background="LightGray"
		Width="800"
		Height="450">

	<Panel Width="800" Height="450">
		<Panel VerticalAlignment="Top" HorizontalAlignment="Center" Width="800" Height="150">
			<Button Width="800" Height="150" Background="AliceBlue">
				<TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="Consolas" FontSize="60">Buscar</TextBlock>
			</Button>
		</Panel>
		<ScrollViewer Name="scrollViewer" VerticalAlignment="Bottom" Width="800" Height="300">
			<Panel>
				<StackPanel HorizontalAlignment="Left"  Width="400" Height="300" Background="Aqua" Name="pnlSel">

				</StackPanel>
				<StackPanel  HorizontalAlignment="Right" Width="400" Height="300" Background="Aqua" Name="pnlSel2">
					
				</StackPanel>
			</Panel>
		</ScrollViewer>
	</Panel>
	
</Window>
